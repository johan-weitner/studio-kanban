          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "example": "My Album"
                  },
                  "description": {
                    "type": "string",
                    "example": "An optional description"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
